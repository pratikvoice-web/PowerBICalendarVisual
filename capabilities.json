{
  "dataRoles": [
    {
      "displayName": "Date Field",
      "name": "dateCategory",
      "kind": "Grouping"
    },
    {
      "displayName": "Primary Measure (Center)",
      "name": "primaryMeasure",
      "kind": "Measure"
    },
    {
      "displayName": "Secondary Measures",
      "name": "secondaryMeasures",
      "kind": "Measure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "dateCategory": { "max": 1 },
          "primaryMeasure": { "max": 1 },
          "secondaryMeasures": { "min": 0 }
        }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "dateCategory" }
        },
        "values": {
          "select": [
            { "bind": { "to": "primaryMeasure" } },
            { "bind": { "to": "secondaryMeasures" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "calendarColors": {
      "displayName": "Data Colors",
      "properties": {
        "minColor": {
          "displayName": "Minimum Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "maxColor": {
          "displayName": "Maximum Color",
          "type": { "fill": { "solid": { "color": true } } }
        }
      }
    },
    "headerSettings": {
      "displayName": "Calendar Headers",
      "properties": {
        "fontFamily": {
          "displayName": "Font Family",
          "type": { "formatting": { "fontFamily": true } }
        },
        "fontSize": {
          "displayName": "Text Size",
          "type": { "formatting": { "fontSize": true } }
        },
        "fontColor": {
          "displayName": "Font Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "backgroundColor": {
          "displayName": "Background Color",
          "type": { "fill": { "solid": { "color": true } } }
        }
      }
    },
    "cellSettings": {
      "displayName": "Grid and Cells",
      "properties": {
        "fontFamily": {
          "displayName": "Font Family",
          "type": { "formatting": { "fontFamily": true } }
        },
        "fontSize": {
          "displayName": "Primary Text Size",
          "type": { "formatting": { "fontSize": true } }
        },
        "fontColor": {
          "displayName": "Primary Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "borderColor": {
          "displayName": "Border Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "borderThickness": {
          "displayName": "Border Thickness",
          "type": { "integer": true }
        }
      }
    },
    "labelSettings": {
      "displayName": "Secondary Data Labels",
      "properties": {
        "show": {
          "displayName": "Show Labels",
          "type": { "bool": true }
        },
        "fontSize": {
          "displayName": "Label Size",
          "type": { "formatting": { "fontSize": true } }
        },
        "fontColor": {
          "displayName": "Label Color",
          "type": { "fill": { "solid": { "color": true } } }
        }
      }
    }
  },
  "supportsHighlight": true,
  "privileges": []
}
